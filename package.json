{
  "name": "semantic-audio-annotator",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop-first annotation tool for curating audio-text pairs for semantic audio retrieval research.",
  "main": ".electron/electron/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 .electron/electron/main.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p electron/tsconfig.json",
    "check-types": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^4.5.14",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.research.semantic-audio-annotator",
    "productName": "Semantic Audio Annotator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      ".electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
