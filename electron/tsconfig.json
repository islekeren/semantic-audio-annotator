{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "outDir": "../.electron",
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../src/shared/**/*.ts"]
}
